# Weather tile on the home bento grid (Open-Meteo, no API key required).
# Defaults to Berkeley, CA if unset.

# Option A: city name (geocoded via Open-Meteo)
WEATHER_CITY=Berkeley

# Option B: exact coordinates (overrides WEATHER_CITY when both lat and lon are set)
# WEATHER_LAT=37.8715
# WEATHER_LON=-122.273
